{
    "openapi": "3.1.1",
    "paths": {
        "/auth/signup": {
            "post": {
                "operationId": "AuthController_signup",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/SignupDto" }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "User successfully registered" },
                    "400": { "description": "Bad Request" }
                },
                "summary": "Register a new user",
                "tags": ["Authentication"]
            }
        },
        "/auth/login": {
            "post": {
                "operationId": "AuthController_login",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/LoginDto" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "User successfully logged in",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TokenResponseDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                },
                "summary": "Login",
                "tags": ["Authentication"]
            }
        },
        "/auth/me": {
            "get": {
                "operationId": "AuthController_me",
                "parameters": [],
                "responses": {
                    "200": {
                        "description": "Current user info",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/UserDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Get current user info",
                "tags": ["Authentication"]
            }
        },
        "/auth/logout": {
            "post": {
                "operationId": "AuthController_logout",
                "parameters": [],
                "responses": {
                    "200": { "description": "User successfully logged out" },
                    "401": { "description": "Unauthorized" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Logout",
                "tags": ["Authentication"]
            }
        },
        "/auth/refresh": {
            "post": {
                "operationId": "AuthController_refresh",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/RefreshTokenDto" }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Token successfully refreshed",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/TokenResponseDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Refresh authentication token",
                "tags": ["Authentication"]
            }
        },
        "/health": {
            "get": {
                "operationId": "HealthController_check",
                "parameters": [],
                "responses": {
                    "200": {
                        "description": "The Health Check is successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": { "type": "string", "example": "ok" },
                                        "info": {
                                            "type": "object",
                                            "example": { "database": { "status": "up" } },
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            },
                                            "nullable": true
                                        },
                                        "error": {
                                            "type": "object",
                                            "example": {},
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            },
                                            "nullable": true
                                        },
                                        "details": {
                                            "type": "object",
                                            "example": { "database": { "status": "up" } },
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "503": {
                        "description": "The Health Check is not successful",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": { "type": "string", "example": "error" },
                                        "info": {
                                            "type": "object",
                                            "example": { "database": { "status": "up" } },
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            },
                                            "nullable": true
                                        },
                                        "error": {
                                            "type": "object",
                                            "example": {
                                                "redis": {
                                                    "status": "down",
                                                    "message": "Could not connect"
                                                }
                                            },
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            },
                                            "nullable": true
                                        },
                                        "details": {
                                            "type": "object",
                                            "example": {
                                                "database": { "status": "up" },
                                                "redis": {
                                                    "status": "down",
                                                    "message": "Could not connect"
                                                }
                                            },
                                            "additionalProperties": {
                                                "type": "object",
                                                "required": ["status"],
                                                "properties": { "status": { "type": "string" } },
                                                "additionalProperties": true
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "summary": "Gets the health status of the SIEVE backend service",
                "tags": ["Health"]
            }
        },
        "/users": {
            "get": {
                "description": "Only contains a simplified view of a user",
                "operationId": "UserController_getUsers",
                "parameters": [
                    {
                        "name": "page",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "limit",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "role",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Users successfully retrieved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": { "$ref": "#/components/schemas/SimpleUserDto" }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" }
                },
                "security": [{ "bearer": [] }],
                "summary": "List all users (admin only)",
                "tags": ["Users"]
            }
        },
        "/users/{userId}": {
            "get": {
                "operationId": "UserController_getUserById",
                "parameters": [
                    {
                        "name": "userId",
                        "required": true,
                        "in": "path",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User successfully retrieved",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/UserDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "403": { "description": "Forbidden" },
                    "404": { "description": "User not found" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Get detailed user information (admin only)",
                "tags": ["Users"]
            }
        },
        "/jobs": {
            "get": {
                "operationId": "JobController_getJobs",
                "parameters": [
                    {
                        "name": "page",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "limit",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "number" }
                    },
                    {
                        "name": "status",
                        "required": true,
                        "in": "query",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Jobs successfully retrieved.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": { "$ref": "#/components/schemas/JobDto" }
                                }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" }
                },
                "security": [{ "bearer": [] }],
                "summary": "List jobs (filtered by user unless admin)",
                "tags": ["Jobs"]
            }
        },
        "/jobs/{jobId}": {
            "get": {
                "operationId": "JobController_getJobById",
                "parameters": [
                    {
                        "name": "jobId",
                        "required": true,
                        "in": "path",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Job successfully retrieved.",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/JobDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "404": { "description": "Job not found" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Get detailed job information",
                "tags": ["Jobs"]
            }
        },
        "/jobs/{jobId}/result": {
            "get": {
                "operationId": "JobController_getJobResult",
                "parameters": [
                    {
                        "name": "jobId",
                        "required": true,
                        "in": "path",
                        "schema": { "type": "string" }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Job result successfully retrieved.",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/JobResultDto" }
                            }
                        }
                    },
                    "401": { "description": "Unauthorized" },
                    "404": { "description": "Job or result not found" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Get job result output",
                "tags": ["Jobs"]
            }
        },
        "/emails": {
            "post": {
                "operationId": "EmailController_submitEmail",
                "parameters": [],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": { "$ref": "#/components/schemas/CreateEmailDto" }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Successfully submitted",
                        "content": {
                            "application/json": {
                                "schema": { "$ref": "#/components/schemas/JobDto" }
                            }
                        }
                    },
                    "400": { "description": "Bad Request" },
                    "401": { "description": "Unauthorized" }
                },
                "security": [{ "bearer": [] }],
                "summary": "Submit an email for processing",
                "tags": ["Emails"]
            }
        }
    },
    "info": {
        "title": "SIEVE",
        "description": "This is the OpenAPI specification for the communication to the SIEVE backend via the REST-API. The SIEVE frontend and backend communicate via this API.",
        "version": "0.1.0",
        "contact": {},
        "license": { "name": "GPLv3-or-later", "url": "https://www.gnu.org/licenses/gpl-3.0.html" }
    },
    "tags": [
        {
            "name": "Authentication",
            "description": "Endpoints for user authentication and session management."
        },
        {
            "name": "Users",
            "description": "Endpoints for listing and inspecting users. Accessible only to users with admin roles."
        },
        {
            "name": "Emails",
            "description": "Endpoints for submitting and managing uploaded emails. Each uploaded email triggers job creation and processing in the backend."
        },
        {
            "name": "Jobs",
            "description": "Endpoints to list or inspect background processing jobs created by the user."
        },
        {
            "name": "Health",
            "description": "Endpoint to check the health status of the SIEVE backend service."
        }
    ],
    "servers": [],
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "type": "http",
                "description": "JWT Bearer token authentication"
            }
        },
        "schemas": {
            "SignupDto": {
                "type": "object",
                "properties": {
                    "name": { "type": "string", "example": "John Doe" },
                    "email": { "type": "string", "example": "john.doe@example.com" },
                    "password": { "type": "string", "example": "strongPassword123!" }
                },
                "required": ["name", "email", "password"]
            },
            "LoginDto": {
                "type": "object",
                "properties": {
                    "email": { "type": "string", "example": "john.doe@example.com" },
                    "password": { "type": "string", "example": "strongPassword123!" }
                },
                "required": ["email", "password"]
            },
            "TokenResponseDto": { "type": "object", "properties": {} },
            "UserDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique user ID",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "name": {
                        "type": "string",
                        "description": "Full name of the user",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "description": "Email address of the user",
                        "example": "john.doe@example.com"
                    },
                    "role": {
                        "type": "string",
                        "description": "Role of the user",
                        "enum": ["ADMIN", "USER"],
                        "example": "USER"
                    },
                    "createdAt": {
                        "type": "string",
                        "description": "Creation timestamp",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "description": "Last update timestamp",
                        "format": "date-time",
                        "nullable": true
                    },
                    "deletedAt": {
                        "type": "string",
                        "description": "Deletion timestamp, if soft-deleted",
                        "format": "date-time",
                        "nullable": true
                    },
                    "jobs": {
                        "description": "IDs of jobs created by the user",
                        "type": "array",
                        "items": { "type": "string" }
                    },
                    "emails": {
                        "description": "IDs of emails uploaded by the user",
                        "type": "array",
                        "items": { "type": "string" }
                    }
                },
                "required": ["id", "name", "email", "role", "createdAt"]
            },
            "RefreshTokenDto": { "type": "object", "properties": {} },
            "SimpleUserDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique user ID",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "name": {
                        "type": "string",
                        "description": "Full name of the user",
                        "example": "John Doe"
                    },
                    "email": {
                        "type": "string",
                        "description": "Email address of the user",
                        "example": "john.doe@example.com"
                    },
                    "role": {
                        "type": "string",
                        "description": "Role of the user",
                        "enum": ["ADMIN", "USER"],
                        "example": "USER"
                    }
                },
                "required": ["id", "name", "email", "role"]
            },
            "JobDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique job ID",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "status": {
                        "type": "string",
                        "description": "Current status of the job",
                        "enum": ["CREATED", "PENDING", "PROCESSING", "COMPLETED"],
                        "example": "CREATED"
                    },
                    "userId": {
                        "type": "string",
                        "description": "User ID who created the job",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "emailId": {
                        "type": "string",
                        "description": "Email ID associated with this job",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "startedAt": {
                        "type": "string",
                        "description": "Job start timestamp",
                        "format": "date-time",
                        "nullable": true
                    },
                    "completedAt": {
                        "type": "string",
                        "description": "Job completion timestamp",
                        "format": "date-time",
                        "nullable": true
                    },
                    "createdAt": {
                        "type": "string",
                        "description": "Creation timestamp",
                        "format": "date-time"
                    },
                    "deletedAt": {
                        "type": "string",
                        "description": "Deletion timestamp if soft-deleted",
                        "format": "date-time",
                        "nullable": true
                    },
                    "resultId": {
                        "type": "string",
                        "description": "Associated JobResult ID, if completed",
                        "nullable": true
                    }
                },
                "required": ["id", "status", "userId", "emailId", "createdAt"]
            },
            "JobResultDto": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "string",
                        "description": "Unique JobResult ID",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "jobId": {
                        "type": "string",
                        "description": "Associated Job ID",
                        "example": "ff1fa1cb-d247-43ec-87d7-4033ae527b2d"
                    },
                    "status": {
                        "type": "string",
                        "description": "Status of the job result",
                        "enum": ["SUCCESS", "FAILURE"],
                        "example": "SUCCESS"
                    },
                    "output": { "type": "object", "description": "JSON output of the job" },
                    "createdAt": {
                        "type": "string",
                        "description": "Creation timestamp",
                        "format": "date-time"
                    },
                    "deletedAt": {
                        "type": "string",
                        "description": "Deletion timestamp if soft-deleted",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "required": ["id", "jobId", "status", "output", "createdAt"]
            },
            "CreateEmailDto": {
                "type": "object",
                "properties": {
                    "sender": {
                        "type": "string",
                        "description": "Sender of the email",
                        "example": "alice.smith@example.com",
                        "nullable": true
                    },
                    "subject": {
                        "type": "string",
                        "description": "Subject of the email",
                        "example": "Piece Availability Request",
                        "nullable": true
                    },
                    "body": {
                        "type": "string",
                        "description": "Body of the email",
                        "example": "Dear Sir or Madam,\n\nI would like to request information regarding the availability of the following pieces...\n\nBest regards,\nAlice Smith"
                    }
                },
                "required": ["body"]
            }
        }
    },
    "externalDocs": {
        "description": "Documentation",
        "url": "https://github.com/SE-UUlm/sieve/wiki"
    }
}
